# ===========================================
# Salt Safari - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# One-off purchase price ID (Phase 3)
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# --- Resend (email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@saltsafari.app

# --- iNaturalist ---
# No auth required for basic API access (100 req/min)
# Register an app for higher limits: https://www.inaturalist.org/oauth/applications
INATURALIST_APP_ID=
INATURALIST_APP_SECRET=

# --- Google ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
GOOGLE_GEOCODING_API_KEY=

# --- Rewardful (affiliate tracking) - Phase 3 ---
# NEXT_PUBLIC_REWARDFUL_API_KEY=
# REWARDFUL_SECRET_KEY=

# --- App Config ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
